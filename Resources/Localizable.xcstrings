{
  "sourceLanguage": "en",
  "strings": {
    "Appearance": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "外观"
          }
        }
      }
    },
    "Bundled Core": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "内置核心"
          }
        }
      }
    },
    "Choose the app color scheme.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择 App 配色方案。"
          }
        }
      }
    },
    "Current app language: %@. Change per-app language in macOS Language & Region, then reopen ClashMax if needed.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当前 App 语言：%@。请在 macOS“语言与地区”中更改单个 App 语言，必要时重新打开 ClashMax。"
          }
        }
      }
    },
    "Developer Mode": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "开发者模式"
          }
        }
      }
    },
    "General": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "通用"
          }
        }
      }
    },
    "Helper not found in the app bundle. Clean build and run ClashMax again.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "App 包内未找到 helper。请清理构建后重新运行 ClashMax。"
          }
        }
      }
    },
    "Helper not registered. Click Register or Start in TUN mode.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Helper 尚未注册。请点击“注册”，或在 TUN 模式下启动。"
          }
        }
      }
    },
    "Helper registered and bootstrapped.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Helper 已注册并完成启动准备。"
          }
        }
      }
    },
    "Helper registered but not bootstrapped. Open System Settings > General > Login Items & Extensions, approve ClashMax, then click Repair or restart macOS.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Helper 已注册但尚未完成启动准备。请打开“系统设置 > 通用 > 登录项与扩展”，批准 ClashMax，然后点击“修复”或重启 macOS。"
          }
        }
      }
    },
    "Helper registered. Approve ClashMax in System Settings > General > Login Items & Extensions, then click Status.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Helper 已注册。请在“系统设置 > 通用 > 登录项与扩展”中批准 ClashMax，然后点击“状态”。"
          }
        }
      }
    },
    "Helper registered. Verifying helper connection.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Helper 已注册，正在验证连接。"
          }
        }
      }
    },
    "Helper status is unknown. Clean build and run ClashMax again.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Helper 状态未知。请清理构建后重新运行 ClashMax。"
          }
        }
      }
    },
    "Language": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "语言"
          }
        }
      }
    },
    "Launch": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "启动"
          }
        }
      }
    },
    "Launch at Login": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "登录时启动"
          }
        }
      }
    },
    "Open Language & Region": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "打开语言与地区"
          }
        }
      }
    },
    "Open System Settings > General > Language & Region.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "打开“系统设置 > 通用 > 语言与地区”。"
          }
        }
      }
    },
    "Open Settings": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "打开设置"
          }
        }
      }
    },
    "Preparing the TUN helper with macOS.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "正在通过 macOS 准备 TUN helper。"
          }
        }
      }
    },
    "Profile must include at least one proxy or proxy provider.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "配置必须至少包含一个代理或代理提供者。"
          }
        }
      }
    },
    "Profile response is empty.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "配置响应为空。"
          }
        }
      }
    },
    "Proxy Routing": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "代理路由"
          }
        }
      }
