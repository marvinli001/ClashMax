    "Warning": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "警告"
          }
        }
      }
    },
    "When enabled, ClashMax hides its main window during login-item startup. Open it from the menu bar when needed.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "启用后，ClashMax 通过登录项启动时会隐藏主窗口。需要时可从菜单栏打开。"
          }
        }
      }
    },
    "Write app-managed DNS options into the runtime profile.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将 App 管理的 DNS 选项写入运行时配置。"
