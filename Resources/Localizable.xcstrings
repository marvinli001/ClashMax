      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "TUN Helper"
          }
        }
      }
    },
    "TUN Helper Status": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "TUN Helper 状态"
          }
        }
      }
    },
    "TUN helper is ready.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "TUN helper 已就绪。"
          }
        }
      }
    },
    "TUN helper needs preparation before Start is available.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "TUN helper 需要先完成准备，之后才能启动。"
          }
        }
      }
    },
    "Updates": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "更新"
          }
        }
      }
    },
    "YAML parse error: %@": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "YAML 解析错误：%@"
          }
        }
      }
    },
    "YAML root must be a mapping or URI/base64 proxy-provider content.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "YAML 根节点必须是映射，或 URI/base64 代理提供者内容。"
          }
        }
      }
    },
    "%@ for external web dashboards at %@ with Bearer auth.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%@，外部 Web 面板地址为 %@，使用 Bearer 认证。"
          }
        }
      }
    },
    "App Package": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "App 包"
          }
        }
      }
    },
    "Approve ClashMax in System Settings > General > Login Items & Extensions.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请在“系统设置 > 通用 > 登录项与扩展”中批准 ClashMax。"
          }
        }
      }
    },
    "Bundled Mihomo core information is unavailable.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法读取内置 Mihomo 核心信息。"
          }
        }
      }
    },
    "Bundled with ClashMax. Updating ClashMax updates the bundled Mihomo core.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "随 ClashMax 内置。更新 ClashMax 时会更新内置 Mihomo 核心。"
          }
        }
      }
    },
    "Check Updates": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "检查更新"
          }
        }
      }
    },
    "Checking for updates is not configured for this build.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此构建未配置更新检查。"
