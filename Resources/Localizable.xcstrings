    "Register": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "注册"
          }
        }
      }
    },
    "Repair": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "修复"
          }
        }
      }
    },
    "Runtime overrides and system integration controls.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "运行时覆盖项与系统集成控制。"
          }
        }
      }
    },
    "Settings": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "设置"
          }
        }
      }
    },
    "Show helper diagnostics and advanced recovery details.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "显示 helper 诊断与高级恢复详情。"
