            "value": "系统代理"
          }
        }
      }
    },
    "System Proxy mode does not need a privileged helper. Switch to TUN if you want VPN-style routing for non-HTTP traffic.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "系统代理模式不需要特权 helper。如果需要为非 HTTP 流量提供 VPN 风格路由，请切换到 TUN。"
          }
        }
      }
    },
    "TUN": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "TUN"
          }
        }
      }
    },
    "Unified Delay": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "统一延迟"
          }
        }
      }
